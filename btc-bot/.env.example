# ─── Variables d'environnement — Railway / .env local ───
# NE JAMAIS commiter ce fichier sur GitHub !

# Mode simulation (true = pas de vrais ordres)
DRY_RUN=true

# Binance — obtenir sur https://www.binance.com/fr/my/settings/api-management
BINANCE_API_KEY=ta_cle_ici
BINANCE_API_SECRET=ton_secret_ici

# Telegram — créer un bot via @BotFather
TELEGRAM_TOKEN=ton_token_telegram
TELEGRAM_CHAT_ID=ton_chat_id

# Capital simulé/réel en USDT
CAPITAL_USDT=300

# Glassnode — plan gratuit sur https://glassnode.com
GLASSNODE_API_KEY=ta_cle_glassnode

# FRED (taux Fed) — gratuit sur https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=ta_cle_fred
