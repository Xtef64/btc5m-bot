# ══════════════════════════════════════════
# Polymarket BTC 5-Min Bot — Variables env
# ══════════════════════════════════════════

# Mode DRY RUN (true = simulation, false = live trading)
DRY_RUN=true

# Bankroll simulée (en USD)
STARTING_BANKROLL=300.0

# Taille de mise (% du bankroll par trade)
BET_SIZE_PCT=0.05

# Mise min/max en USD
MIN_BET=2.0
MAX_BET=25.0

# Entrer dans les X dernières secondes de la fenêtre
ENTRY_SECONDS_BEFORE=30

# Delta BTC minimum pour trader (en %)
# 0.03 = 0.03% de mouvement requis depuis l'ouverture de fenêtre
MIN_CONFIDENCE_PCT=0.03

# Telegram (optionnel — laisser vide si pas besoin)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
